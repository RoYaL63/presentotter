{
  "name": "presentotter",
  "version": "0.5.13",
  "description": "Open source screen recorder for no-code educators",
  "main": "dist/main/main.js",
  "homepage": "https://github.com/RoYaL63/presentotter",
  "author": "OTTERWISE Solutions <otterwise-solutions@proton.me>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "concurrently -k -n MAIN,REND,ELEC -c blue,green,magenta \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 dist/main/main.js && cross-env NODE_ENV=development electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "pack:win": "npm run build && node scripts/package-win.js",
    "installer:win": "npm run pack:win && node scripts/build-installer.js",
    "release": "node scripts/release.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run integration-tests",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.main.json",
    "check:secrets": "node scripts/check-secrets.js"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "better-sqlite3": "^9.4.0",
    "electron-store": "^8.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "rxjs": "^7.8.1",
    "tesseract.js": "^5.0.4",
    "uiohook-napi": "^1.5.3"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^8.56.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.0"
  }
}
